---
/**
 * 서울 허브 페이지 (/seoul/)
 * 스펙 9절 서울 구조 - 25개 행정구 + 핵심 생활권
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Checklist from '../../components/Checklist.astro';
import PriceTable from '../../components/PriceTable.astro';
import PhoneCTA from '../../components/PhoneCTA.astro';
import { getDistricts, getReadyLifeAreas } from '../../lib/data';
import { breadcrumbSchema, webPageSchema, organizationSchema } from '../../lib/schema';

const path = '/seoul/';
const title = '서울 출장마사지｜25개 행정구 방문 가능 지역 안내';
const description =
  '서울 출장마사지 25개 행정구별 방문 가능 지역과 행정동, 역세권, 예약 전 확인사항을 안내합니다.';

const districts = getDistricts('seoul');
const seoulAreas = getReadyLifeAreas('seoul');

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '서울', url: '/seoul/' },
];

const schemas = [
  organizationSchema(),
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 32px 0 40px;">
      <div class="tag tag-accent" style="margin-bottom: 16px;">
        서울 · 수도권 출장마사지
      </div>
      <h1 style="font-size: 2.2rem; font-weight: 800; line-height: 1.3; letter-spacing: -0.02em; margin-bottom: 16px;">
        서울 출장마사지 · <span class="accent-text">25개 행정구</span> 안내
      </h1>
      <p style="font-size: 1.05rem; color: var(--color-text-soft); max-width: 680px; line-height: 1.7;">
        서울은 25개 행정구와 핵심 역세권, 생활권을 기준으로 방문 환경을 안내합니다.
        행정구를 클릭하면 해당 구의 방문 가능 지역과 예약 전 확인사항을 확인할 수 있습니다.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 22px;">
        <a href="/life/" class="btn btn-outline btn-sm">생활권 보기</a>
        <a href="/station/" class="btn btn-outline btn-sm">지하철역 보기</a>
        <a href="/use/" class="btn btn-outline btn-sm">이용 장소</a>
        <a href="/check/" class="btn btn-outline btn-sm">예약 전 확인</a>
      </div>
    </section>

    <section class="section" style="border-top: 1px solid var(--color-border); padding-top: 48px;">
      <h2 class="section-title">서울 25개 행정구</h2>
      <p class="section-subtitle">
        행정구를 클릭하면 행정동 방문 가능 지역과 역세권을 확인할 수 있습니다.
      </p>
      <div class="card-grid">
        {districts.map((d) => (
          <a href={`/seoul/${d.slug}/`} class="card">
            <h3 class="card__title">{d.name}</h3>
            <p class="card__desc">{d.description}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px;">
              <span class="tag tag-accent">{d.contentFocus}</span>
            </div>
            <span class="card__link">자세히 보기 →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section" style="border-top: 1px solid var(--color-border);">
      <PriceTable title="서울 출장마사지 가격표" />
    </section>

    <PhoneCTA region="서울" />

    {seoulAreas.length > 0 && (
      <section class="section" style="border-top: 1px solid var(--color-border);">
        <h2 class="section-title">서울 핵심 생활권</h2>
        <p class="section-subtitle">
          행정구가 아닌 실제 생활권 단위로 방문 특성을 확인하세요.
        </p>
        <div class="card-grid">
          {seoulAreas.map((area) => (
            <a href={`/seoul/life/${area.slug}/`} class="card">
              <div class="tag tag-accent" style="margin-bottom: 12px; display: inline-block;">서울 생활권</div>
              <h3 class="card__title">{area.name}</h3>
              <p class="card__desc">{area.description}</p>
              <span class="card__link">방문 가능 지역 보기 →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="section" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

  </div>
</BaseLayout>
