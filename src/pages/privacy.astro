---
/**
 * 개인정보 처리방침 (/privacy/)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { siteConfig } from '../data/site';
import { breadcrumbSchema, webPageSchema, organizationSchema, serviceSchema } from '../lib/schema';

const path = '/privacy/';
const title = '개인정보 처리방침｜WE 마사지';
const description =
  'WE 마사지 개인정보 처리방침. 수집 항목, 이용 목적, 보유 기간, 이용자 권리를 안내합니다.';

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '개인정보 처리방침', url: '/privacy/' },
];

const schemas = [
  organizationSchema(),
  serviceSchema({ description, path }),
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 24px 0 32px;">
      <h1 style="font-size: 2rem; font-weight: 800; line-height: 1.35; margin-bottom: 14px;">개인정보 처리방침</h1>
      <p style="color: var(--color-text-soft); font-size: 0.95rem;">최종 수정일: 2026-06-28</p>
    </section>

    <section class="section-sm">
      <div class="prose">
        <h2>1. 수집하는 개인정보 항목</h2>
        <p>
          {siteConfig.name}은 예약 안내를 위해 다음의 최소한의 개인정보를 수집합니다.
        </p>
        <ul>
          <li>연락처(전화번호) — 예약 안내·연락 목적</li>
          <li>방문 주소 — 방문 가능 지역 확인·이동 목적</li>
          <li>예약 희망 시간 — 예약 조율 목적</li>
        </ul>

        <h2>2. 수집·이용 목적</h2>
        <p>
          수집된 정보는 예약 안내, 방문 가능 지역 확인, 예약 변경·취소 안내 목적으로만 사용되며,
          이용자 동의 없이 다른 목적으로 사용되지 않습니다.
        </p>

        <h2>3. 보유 및 이용 기간</h2>
        <p>
          예약 안내 목적 달성 후 즉시 파기합니다. 단, 관련 법령에 따라 보존이 필요한 경우 해당 기간 동안 보관합니다.
        </p>

        <h2>4. 이용자 권리</h2>
        <p>
          이용자는 언제든지 본인의 개인정보 열람·정정·삭제를 요청할 수 있습니다.
          요청은 전화예약({siteConfig.phoneDisplay})을 통해 접수됩니다.
        </p>

        <h2>5. 개인정보 제3자 제공</h2>
        <p>
          원칙적으로 이용자의 동의 없이 개인정보를 제3자에게 제공하지 않습니다.
          단, 관련 법령에 의거해 필요한 경우는 예외로 합니다.
        </p>

        <h2>6. 문의</h2>
        <p>
          개인정보 처리 관련 문의는 전화예약(<a href={`tel:${siteConfig.phoneTel}`}>{siteConfig.phoneDisplay}</a>)로 연락해 주세요.
        </p>
      </div>
    </section>

  </div>
</BaseLayout>
