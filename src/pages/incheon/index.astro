---
/**
 * 인천 허브 페이지 (/incheon/)
 * 스펙 11절 인천 구조 - 9구 2군 (2026.7.1 개편체제 메인) + 생활권
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Checklist from '../../components/Checklist.astro';
import PriceTable from '../../components/PriceTable.astro';
import PhoneCTA from '../../components/PhoneCTA.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import Reviews from '../../components/Reviews.astro';
import { getDistricts, getReadyLifeAreas, getLongtailLifeLinks } from '../../lib/data';
import {
  breadcrumbSchema,
  webPageSchema,
  organizationSchema,
  serviceSchema,
  itemListSchema,
} from '../../lib/schema';

const path = '/incheon/';
const title = '인천 출장마사지｜9구 2군 방문 가능 지역 안내';
const description =
  '인천 출장마사지 9구 2군(2026.7.1 개편 반영)별 방문 가능 지역과 생활권, 공항·도서, 예약 전 확인사항을 안내합니다.';

const districts = getDistricts('incheon');
const incheonAreas = getReadyLifeAreas('incheon');

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '인천', url: '/incheon/' },
];

const longtailLinks = getLongtailLifeLinks('incheon');
const listItems = [
  ...districts.filter((d) => !d.noindex).map((d) => ({ name: `인천 ${d.name} 출장마사지`, url: `/incheon/${d.slug}/` })),
  ...incheonAreas.map((a) => ({ name: `${a.name} 출장마사지`, url: `/incheon/life/${a.slug}/` })),
];

const schemas = [
  organizationSchema(),
  serviceSchema({ name: '인천 출장마사지', description, areaServed: ['인천'], path }),
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  itemListSchema(listItems, '인천 출장마사지 구·군·생활권 안내'),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 32px 0 40px;">
      <div class="tag tag-accent" style="margin-bottom: 16px;">
        인천 · 수도권 출장마사지
      </div>
      <h1 style="font-size: 2.2rem; font-weight: 800; line-height: 1.3; letter-spacing: -0.02em; margin-bottom: 16px;">
        인천 출장마사지 · <span class="accent-text">9구 2군</span> 안내
      </h1>
      <p style="font-size: 1.05rem; color: var(--color-text-soft); max-width: 680px; line-height: 1.7;">
        인천은 9구 2군 생활권과 공항·도서 지역 특성을 함께 안내합니다. 구·군을 클릭하면
        해당 지역의 방문 가능 지역과 예약 전 확인사항을 확인할 수 있습니다.
        강화·옹진은 도서 지역 특성상 사전 예약과 추가 이동비 확인이 필요합니다.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 22px;">
        <a href="/life/" class="btn btn-outline btn-sm">생활권 보기</a>
        <a href="/station/" class="btn btn-outline btn-sm">지하철역 보기</a>
        <a href="/use/" class="btn btn-outline btn-sm">이용 장소</a>
        <a href="/check/" class="btn btn-outline btn-sm">예약 전 확인</a>
      </div>
    </section>

    <div class="callout callout-info" style="margin: 0 0 32px;">
      <div class="callout__title">인천 행정구역 개편 안내 (2026.7.1 시행)</div>
      2026년 7월 1일부터 인천이 8구 2군에서 <strong>9구 2군</strong>으로 개편됩니다.
      신설 <strong>제물포구·영종구·검단구</strong>와 명칭 변경 <strong>서해구</strong>(구 서구 남부)를 반영했습니다.
      기존 동구는 제물포구에 통합됩니다.
    </div>

    <section class="section" style="border-top: 1px solid var(--color-border); padding-top: 48px;">
      <h2 class="section-title">인천 9구 2군</h2>
      <p class="section-subtitle">
        구·군을 클릭하면 방문 가능 지역과 역세권을 확인할 수 있습니다.
      </p>
      <div class="card-grid">
        {districts.map((d) => (
          <a href={`/incheon/${d.slug}/`} class="card" aria-label={d.noindex ? `${d.name} (준비 중)` : d.name}>
            <h3 class="card__title">{d.name}{d.noindex && <span class="tag" style="margin-left:8px;">개편반영</span>}</h3>
            <p class="card__desc">{d.description}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px;">
              <span class="tag tag-accent">{d.contentFocus}</span>
            </div>
            <span class="card__link">자세히 보기 →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section" style="border-top: 1px solid var(--color-border);">
      <PriceTable title="인천 출장마사지 가격표" />
    </section>

    <PhoneCTA region="인천" />

    {incheonAreas.length > 0 && (
      <section class="section" style="border-top: 1px solid var(--color-border);">
        <h2 class="section-title">인천 핵심 생활권</h2>
        <p class="section-subtitle">
          구·군이 아닌 실제 생활권 단위로 방문 특성과 공항·도서 접근성을 확인하세요.
        </p>
        <div class="card-grid">
          {incheonAreas.map((area) => (
            <a href={`/incheon/life/${area.slug}/`} class="card">
              <div class="tag tag-accent" style="margin-bottom: 12px; display: inline-block;">인천 생활권</div>
              <h3 class="card__title">{area.name}</h3>
              <p class="card__desc">{area.description}</p>
              <span class="card__link">방문 가능 지역 보기 →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <Reviews title="인천 출장마사지 이용자 후기" />

    <RelatedLinks
      title="인천 인기 검색 지역 바로가기"
      subtitle="자주 찾는 생활권·역세권 키워드로 바로 이동하세요."
      links={longtailLinks}
      variant="chip"
    />

    <section class="section" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

  </div>
</BaseLayout>
