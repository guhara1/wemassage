---
/**
 * 404 페이지
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { webPageSchema } from '../lib/schema';

const path = '/404/';
const title = '페이지를 찾을 수 없습니다｜WE 마사지';
const description = '요청하신 페이지를 찾을 수 없습니다. 수도권 출장마사지 메인으로 이동하세요.';

const schemas = [webPageSchema(path, title, description)];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container" style="text-align: center; padding: 80px 24px;">
    <div style="font-size: 4rem; font-weight: 900; background: var(--gradient-accent); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 16px;">
      404
    </div>
    <h1 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 16px;">페이지를 찾을 수 없습니다</h1>
    <p style="color: var(--color-text-soft); margin-bottom: 32px;">
      요청하신 페이지가 존재하지 않거나 이동되었을 수 있습니다.
    </p>
    <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a href="/" class="btn btn-accent btn-lg">홈으로</a>
      <a href="/area/" class="btn btn-outline btn-lg">지역별 보기</a>
      <a href="/check/" class="btn btn-ghost btn-lg">예약 전 확인</a>
    </div>
  </div>
</BaseLayout>
