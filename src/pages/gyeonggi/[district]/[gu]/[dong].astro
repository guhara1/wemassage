---
/**
 * 경기 일반구 내 행정동 상세 페이지 (동적)
 * /gyeonggi/[district]/[gu]/[dong]/
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import Checklist from '../../../../components/Checklist.astro';
import PriceTable from '../../../../components/PriceTable.astro';
import PhoneCTA from '../../../../components/PhoneCTA.astro';
import FAQ from '../../../../components/FAQ.astro';
import RelatedLinks from '../../../../components/RelatedLinks.astro';
import Reviews from '../../../../components/Reviews.astro';
import {
  getGuDistricts,
  getDongListByGu,
  getAllUseCases,
  postposition,
} from '../../../../lib/data';
import { webPageSchema, breadcrumbSchema, faqPageSchema, serviceSchema } from '../../../../lib/schema';

export const getStaticPaths = (() => {
  // citySlug → 한국어 시 이름 매핑
  const CITY_NAME: Record<string, string> = {
    suwon: '수원',
    seongnam: '성남',
    yongin: '용인',
    goyang: '고양',
    hwaseong: '화성',
    bucheon: '부천',
    ansan: '안산',
    anyang: '안양',
  };
  const citySlugs = Object.keys(CITY_NAME);
  const paths: { params: { district: string; gu: string; dong: string }; props: { cityName: string; guName: string; dongName: string } }[] = [];
  for (const city of citySlugs) {
    const gus = getGuDistricts(city);
    for (const gu of gus) {
      const dongs = getDongListByGu(city, gu.slug);
      for (const dong of dongs) {
        paths.push({
          params: { district: city, gu: gu.slug, dong: dong.slug },
          props: { cityName: CITY_NAME[city], guName: gu.name, dongName: dong.name },
        });
      }
    }
  }
  return paths;
}) satisfies GetStaticPaths;

interface Props { cityName: string; guName: string; dongName: string; }
const { cityName, guName, dongName } = Astro.props;
const { district, gu, dong } = Astro.params;

const path = `/gyeonggi/${district}/${gu}/${dong}/`;
const dongPP = postposition(dongName, '은는');
const title = `${cityName} ${guName} ${dongName} 출장마사지｜방문 가능 지역`;
const description = `경기 ${cityName} ${guName} ${dongName} 출장마사지. ${dongName} 주변 방문 가능 지역과 예약 전 확인사항을 안내합니다.`;

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '경기', url: '/gyeonggi/' },
  { name: cityName, url: `/gyeonggi/${district}/` },
  { name: guName, url: `/gyeonggi/${district}/${gu}/` },
  { name: dongName, url: path },
];

const useCases = getAllUseCases();

const faqs = [
  {
    question: `${guName} ${dongName}에서 방문 가능한가요?`,
    answer: `네, ${dongName} 방문이 가능합니다. 예약 시 정확한 도로명주소(건물명·동·호수)와 출입 방식을 알려주시면 원활합니다.`,
  },
];

const schemas = [
  serviceSchema({
    name: `${cityName} ${guName} ${dongName} 출장마사지`,
    description,
    areaServed: ['경기', cityName, guName],
    path,
  }),
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  faqPageSchema(faqs),
];

// 같은 일반구의 다른 행정동 + 상위 구·시 롱테일 링크
const siblingLinks = [
  { name: `${cityName} ${guName} 출장마사지`, href: `/gyeonggi/${district}/${gu}/`, badge: '상위 구' },
  { name: `${cityName} 출장마사지`, href: `/gyeonggi/${district}/`, badge: '상위 시' },
  ...getDongListByGu(district!, gu!)
    .filter((d) => d.slug !== dong)
    .slice(0, 8)
    .map((d) => ({
      name: `${guName} ${d.name} 출장마사지`,
      href: `/gyeonggi/${district}/${gu}/${d.slug}/`,
      badge: '같은 구',
    })),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 24px 0 32px;">
      <div class="tag tag-accent" style="margin-bottom: 14px;">경기 · 행정동</div>
      <h1 style="font-size: 2rem; font-weight: 800; line-height: 1.35; margin-bottom: 14px;">
        {cityName} {guName} {dongName} 출장마사지
      </h1>
      <p style="color: var(--color-text-soft); font-size: 1.05rem;">
        경기 {cityName} {guName} {dongName} 중심의 방문 가능 지역 안내입니다. {dongPP}
        아파트·오피스텔·주거 중심 생활권으로 예약 전 아래 확인사항을 점검해 주세요.
      </p>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <div class="prose">
        <p>
          {dongName}은 {cityName} {guName}에 속한 행정동입니다. <strong>건물 출입 방식</strong>을 먼저 확인해 주세요.
          공동현관 비밀번호·도어폰·경비실 출입 절차가 있다면 예약 시 미리 알려주시면 원활한 방문에 도움이 됩니다.
        </p>
        <p>
          신도시·아파트 단지는 공동현관 출입 통제가 일반적이며, 오피스텔은 관리사무소 출입 통제가 있을 수 있어
          예약 시 건물명·출입 방식을 알려주시면 확인해 드립니다.
        </p>
      </div>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <h2 class="section-title">이용 장소에 따라 <span class="accent">확인할 내용</span></h2>
      <div class="card-grid">
        {useCases.map((uc) => (
          <a href={`/use/${uc.slug}/`} class="card">
            <h3 class="card__title">{uc.label}</h3>
            <p class="card__desc">{uc.summary}</p>
            <span class="card__link">확인하기 →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <PriceTable title={`${cityName} ${guName} ${dongName} 출장마사지 가격표`} />
    </section>

    <PhoneCTA region={`경기 ${cityName} ${guName} ${dongName}`} />

    <Reviews title={`${cityName} ${guName} ${dongName} 출장마사지 이용자 후기`} />

    <RelatedLinks
      title={`${guName} 주변 행정동 출장마사지`}
      subtitle="같은 일반구의 다른 동 방문 가능 지역도 함께 확인하세요."
      links={siblingLinks}
      variant="chip"
    />

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <h2 class="section-title" style="font-size: 1.5rem;">자주 묻는 질문</h2>
      <FAQ faqs={faqs} />
    </section>

  </div>
</BaseLayout>
