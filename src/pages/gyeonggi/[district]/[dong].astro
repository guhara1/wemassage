---
/**
 * 경기 행정동·읍면동 상세 페이지 (동적)
 * /gyeonggi/[district]/[dong]/
 * 일반구가 없는 일반시·군의 읍면동.
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Checklist from '../../../components/Checklist.astro';
import PriceTable from '../../../components/PriceTable.astro';
import PhoneCTA from '../../../components/PhoneCTA.astro';
import FAQ from '../../../components/FAQ.astro';
import RelatedLinks from '../../../components/RelatedLinks.astro';
import Reviews from '../../../components/Reviews.astro';
import {
  getDistricts,
  getDistrict,
  getDongList,
  hasGuDistricts,
  getAllUseCases,
  postposition,
} from '../../../lib/data';
import { webPageSchema, breadcrumbSchema, faqPageSchema, serviceSchema } from '../../../lib/schema';

export const getStaticPaths = (() => {
  // 일반구가 없는 일반시·군만 (특례시/부천/안산/안양 제외)
  const skipCities = ['suwon', 'seongnam', 'yongin', 'goyang', 'hwaseong', 'bucheon', 'ansan', 'anyang'];
  const all = getDistricts('gyeonggi').filter((d) => !skipCities.includes(d.slug));
  const paths: { params: { district: string; dong: string }; props: { cityName: string; dongName: string } }[] = [];
  for (const d of all) {
    if (hasGuDistricts(d.slug)) continue;
    const dongs = getDongList('gyeonggi', d.slug);
    for (const dong of dongs) {
      paths.push({
        params: { district: d.slug, dong: dong.slug },
        props: { cityName: d.name, dongName: dong.name },
      });
    }
  }
  return paths;
}) satisfies GetStaticPaths;

interface Props { cityName: string; dongName: string; }
const { cityName, dongName } = Astro.props;
const { district, dong } = Astro.params;

const path = `/gyeonggi/${district}/${dong}/`;
const dongPP = postposition(dongName, '은는');
const title = `경기 ${cityName} ${dongName} 출장마사지｜방문 가능 지역 및 예약 전 확인`;
const description = `경기 ${cityName} ${dongName} 출장마사지. ${dongName} 주변 방문 가능 지역과 예약 전 확인사항, 이용 장소별 기준을 안내합니다.`;

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '경기', url: '/gyeonggi/' },
  { name: cityName, url: `/gyeonggi/${district}/` },
  { name: dongName, url: path },
];

const useCases = getAllUseCases();

const faqs = [
  {
    question: `${cityName} ${dongName}에서 방문 가능한가요?`,
    answer: `네, ${dongName} 방문이 가능합니다. 예약 시 정확한 도로명주소를 안내해 주세요. 외곽 읍면은 추가 이동비가 발생할 수 있습니다.`,
  },
];

const schemas = [
  serviceSchema({
    name: `경기 ${cityName} ${dongName} 출장마사지`,
    description,
    areaServed: ['경기', cityName],
    path,
  }),
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  faqPageSchema(faqs),
];

// 같은 시·군의 다른 읍면동 + 상위 시·군 롱테일 링크
const siblingLinks = [
  { name: `${cityName} 출장마사지`, href: `/gyeonggi/${district}/`, badge: '상위 시·군' },
  ...getDongList('gyeonggi', district!)
    .filter((d) => d.slug !== dong)
    .slice(0, 8)
    .map((d) => ({
      name: `${cityName} ${d.name} 출장마사지`,
      href: `/gyeonggi/${district}/${d.slug}/`,
      badge: '같은 시·군',
    })),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 24px 0 32px;">
      <div class="tag tag-accent" style="margin-bottom: 14px;">경기 · 읍면동</div>
      <h1 style="font-size: 2rem; font-weight: 800; line-height: 1.35; margin-bottom: 14px;">
        {cityName} {dongName} 출장마사지
      </h1>
      <p style="color: var(--color-text-soft); font-size: 1.05rem;">
        경기 {cityName} {dongName} 중심의 방문 가능 지역 안내입니다. {dongPP} 자택·오피스텔·아파트 중심의 생활권으로,
        예약 전 아래 확인사항을 점검해 주세요.
      </p>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <div class="prose">
        <p>
          {dongName}은 {cityName}에 속한 읍·면·동입니다. <strong>건물 출입 방식</strong>과 <strong>주차</strong>를 먼저
          확인해 주세요. 공동현관 비밀번호·도어폰·경비실 출입 절차가 있다면 예약 시 미리 알려주시면 원활합니다.
        </p>
        <p>
          외곽 읍면 지역은 차량 이동 거리가 길어 <strong>추가 이동비</strong>가 발생할 수 있으며,
          심야 시간대에도 추가될 수 있습니다. 예약 시 적용 여부를 확인합니다.
        </p>
      </div>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <h2 class="section-title">이용 장소에 따라 <span class="accent">확인할 내용</span></h2>
      <div class="card-grid">
        {useCases.map((uc) => (
          <a href={`/use/${uc.slug}/`} class="card">
            <h3 class="card__title">{uc.label}</h3>
            <p class="card__desc">{uc.summary}</p>
            <span class="card__link">확인하기 →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <PriceTable title={`${cityName} ${dongName} 출장마사지 가격표`} />
    </section>

    <PhoneCTA region={`경기 ${cityName} ${dongName}`} />

    <Reviews title={`경기 ${cityName} ${dongName} 출장마사지 이용자 후기`} />

    <RelatedLinks
      title={`${cityName} 주변 읍·면·동 출장마사지`}
      subtitle="같은 시·군의 다른 지역 방문 가능 지역도 함께 확인하세요."
      links={siblingLinks}
      variant="chip"
    />

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <h2 class="section-title" style="font-size: 1.5rem;">자주 묻는 질문</h2>
      <FAQ faqs={faqs} />
    </section>

  </div>
</BaseLayout>
