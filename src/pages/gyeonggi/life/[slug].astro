---
/**
 * 경기 생활권 상세 페이지 (동적)
 * /gyeonggi/life/[slug]/
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import Checklist from '../../../components/Checklist.astro';
import PriceTable from '../../../components/PriceTable.astro';
import PhoneCTA from '../../../components/PhoneCTA.astro';
import ExternalSources from '../../../components/ExternalSources.astro';
import RelatedAreas from '../../../components/RelatedAreas.astro';
import ReviewList from '../../../components/ReviewList.astro';
import { getReadyLifeAreas, PROVINCE_LABEL } from '../../../lib/data';
import type { LifeArea, UseCaseSlug } from '../../../lib/types';
import { webPageSchema, breadcrumbSchema, faqPageSchema } from '../../../lib/schema';

export const getStaticPaths = (() => {
  return getReadyLifeAreas('gyeonggi').map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}) satisfies GetStaticPaths;

interface Props { area: LifeArea; }
const { area } = Astro.props;
const path = area.canonicalUrl;
const title = `경기 ${area.name} 출장마사지｜방문 가능 지역 및 예약 전 확인사항`;
const description = `경기 ${area.name} 생활권 출장마사지 방문 가능 지역과 예약 전 확인사항. ${area.description}`;

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '경기', url: '/gyeonggi/' },
  { name: area.name, url: path },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  faqPageSchema(area.faq ?? []),
];

const UC_LABEL: Record<UseCaseSlug, string> = {
  home: '자택 이용',
  hotel: '호텔·숙소 이용',
  officetel: '오피스텔 이용',
  'business-district': '업무지구 이용',
  'station-area': '역세권 이용',
  night: '야간 예약',
  'outer-area': '외곽 지역 이용',
};
---

<BaseLayout title={title} description={description} path={path} noindex={area.noindex} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 24px 0 32px;">
      <div class="tag tag-accent" style="margin-bottom: 14px;">
        {PROVINCE_LABEL[area.province]} 생활권 · {area.contentFocus}
      </div>
      <h1 style="font-size: 2rem; font-weight: 800; line-height: 1.35; margin-bottom: 14px;">
        경기 {area.name} 출장마사지 · 방문 가능 지역
      </h1>
      <p style="color: var(--color-text-soft); font-size: 1.05rem;">{area.description}</p>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <div class="prose">
        <p set:html={(area.body ?? '').replace(/\n/g, '<br />')}></p>
      </div>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <h2 class="section-title">이 생활권에 포함된 지역</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 8px;">
        {area.includes.map((item) => <span class="tag">{item}</span>)}
      </div>
    </section>

    {area.useCases && area.useCases.length > 0 && (
      <section class="section-sm" style="border-top: 1px solid var(--color-border);">
        <h2 class="section-title">이용 장소별 확인사항</h2>
        <div class="card-grid">
          {area.useCases.map((uc) => (
            <a href={`/use/${uc}/`} class="card">
              <h3 class="card__title" style="font-size: 1.05rem;">{UC_LABEL[uc]}</h3>
              <span class="card__link">확인하기 →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

    <PhoneCTA region={`경기 ${area.name}`} />

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <PriceTable title={`경기 ${area.name} 출장마사지 가격표`} />
    </section>

    {area.faq && area.faq.length > 0 && (
      <section class="section-sm" style="border-top: 1px solid var(--color-border);">
        <h2 class="section-title" style="font-size: 1.5rem;">자주 묻는 질문</h2>
        <FAQ faqs={area.faq} />
      </section>
    )}

    {area.externalLinks && area.externalLinks.length > 0 && (
      <ExternalSources links={area.externalLinks} />
    )}

    <ReviewList limit={4} />

    <RelatedAreas province="gyeonggi" currentSlug={area.slug} currentName={area.name} mode="life" maxLife={6} />

  </div>
</BaseLayout>
