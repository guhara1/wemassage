---
/**
 * 경기 허브 페이지 (/gyeonggi/)
 * 스펙 10절 경기 구조 - 31개 시·군(특례시 4곳 포함) + 생활권
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Checklist from '../../components/Checklist.astro';
import PriceTable from '../../components/PriceTable.astro';
import PhoneCTA from '../../components/PhoneCTA.astro';
import RelatedAreas from '../../components/RelatedAreas.astro';
import ReviewList from '../../components/ReviewList.astro';
import { getDistricts, getReadyLifeAreas, getPriceTable, getReviewsData } from '../../lib/data';
import { breadcrumbSchema, webPageSchema, organizationSchema, serviceSchema, reviewsSchema } from '../../lib/schema';

const path = '/gyeonggi/';
const title = '경기 출장마사지｜31개 시·군 방문 가능 지역 안내';
const description =
  '경기도 출장마사지 31개 시·군(수원·고양·용인·화성 특례시 포함)별 방문 가능 지역과 읍면동, 예약 전 확인사항을 안내합니다.';

const districts = getDistricts('gyeonggi');
const gyeonggiAreas = getReadyLifeAreas('gyeonggi');

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '경기', url: '/gyeonggi/' },
];

const schemas = [
  organizationSchema(),
  serviceSchema(getPriceTable(), ['경기']),
  reviewsSchema(getReviewsData(), '경기 출장마사지'),
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 32px 0 40px;">
      <div class="tag tag-accent" style="margin-bottom: 16px;">
        경기 · 수도권 출장마사지
      </div>
      <h1 style="font-size: 2.2rem; font-weight: 800; line-height: 1.3; letter-spacing: -0.02em; margin-bottom: 16px;">
        경기 출장마사지 · <span class="accent-text">31개 시·군</span> 안내
      </h1>
      <p style="font-size: 1.05rem; color: var(--color-text-soft); max-width: 680px; line-height: 1.7;">
        경기도는 31개 시·군(특례시 4곳: 수원·고양·용인·화성)과 신도시, 차량 이동 기준을 함께 안내합니다.
        시·군을 클릭하면 해당 지역의 읍·면·동 방문 가능 지역과 예약 전 확인사항을 확인할 수 있습니다.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 22px;">
        <a href="/life/" class="btn btn-outline btn-sm">생활권 보기</a>
        <a href="/station/" class="btn btn-outline btn-sm">지하철역 보기</a>
        <a href="/use/" class="btn btn-outline btn-sm">이용 장소</a>
        <a href="/check/" class="btn btn-outline btn-sm">예약 전 확인</a>
      </div>
    </section>

    <section class="section" style="border-top: 1px solid var(--color-border); padding-top: 48px;">
      <h2 class="section-title">경기 31개 시·군</h2>
      <p class="section-subtitle">
        시·군을 클릭하면 읍·면·동 방문 가능 지역과 역세권을 확인할 수 있습니다.
      </p>
      <div class="card-grid">
        {districts.map((d) => (
          <a href={`/gyeonggi/${d.slug}/`} class="card">
            <h3 class="card__title">{d.name}</h3>
            <p class="card__desc">{d.description}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px;">
              <span class="tag tag-accent">{d.contentFocus}</span>
            </div>
            <span class="card__link">자세히 보기 →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section" style="border-top: 1px solid var(--color-border);">
      <PriceTable title="경기 출장마사지 가격표" />
    </section>

    <PhoneCTA region="경기" />

    {gyeonggiAreas.length > 0 && (
      <section class="section" style="border-top: 1px solid var(--color-border);">
        <h2 class="section-title">경기 핵심 생활권</h2>
        <p class="section-subtitle">
          시·군이 아닌 실제 생활권 단위로 방문 특성과 차량 이동 기준을 확인하세요.
        </p>
        <div class="card-grid">
          {gyeonggiAreas.map((area) => (
            <a href={`/gyeonggi/life/${area.slug}/`} class="card">
              <div class="tag tag-accent" style="margin-bottom: 12px; display: inline-block;">경기 생활권</div>
              <h3 class="card__title">{area.name}</h3>
              <p class="card__desc">{area.description}</p>
              <span class="card__link">방문 가능 지역 보기 →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="section" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

    <section class="section" style="border-top: 1px solid var(--color-border);">
      <ReviewList limit={4} />
    </section>

    <RelatedAreas province="gyeonggi" currentSlug="gyeonggi" currentName="경기" mode="district" maxDistrict={8} />

  </div>
</BaseLayout>
