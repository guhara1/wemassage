---
/**
 * 수도권 메인 페이지 (/)
 * 스펙 14절 메인 페이지 구성 + 수도권 매트릭스형 4축 안내
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Checklist from '../components/Checklist.astro';
import PriceTable from '../components/PriceTable.astro';
import PhoneCTA from '../components/PhoneCTA.astro';
import ReviewList from '../components/ReviewList.astro';
import { siteConfig } from '../data/site';
import { getReadyLifeAreas, getAllUseCases, getPriceTable, getReviewsData } from '../lib/data';
import {
  webPageSchema,
  breadcrumbSchema,
  organizationSchema,
  webSiteSchema,
  imageObjectSchema,
  serviceSchema,
  reviewsSchema,
} from '../lib/schema';

const path = '/';
const title = siteConfig.title;
const description = siteConfig.description;

// 핵심 생활권 데이터 (1차-A)
const seoulAreas = getReadyLifeAreas('seoul');
const gyeonggiAreas = getReadyLifeAreas('gyeonggi');
const incheonAreas = getReadyLifeAreas('incheon');
const totalLifeAreas = seoulAreas.length + gyeonggiAreas.length + incheonAreas.length;
const totalUseCases = getAllUseCases().length;

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '수도권 출장마사지', url: '/' },
];

const schemas = [
  organizationSchema(),
  webSiteSchema(),
  serviceSchema(getPriceTable()),
  reviewsSchema(getReviewsData()),
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  imageObjectSchema('/og-image.webp'),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container">

    {/* === Hero (2단: 좌 텍스트 / 우 이미지) === */}
    <section class="hero">
      <div class="hero__grid">
        <div class="hero__content">
          <div class="hero__badge">
            <span class="dot"></span>
            서울 · 경기 · 인천 수도권 방문 안내
          </div>
          <h1 class="hero__title">
            수도권 <span class="accent-text">출장마사지</span><br />
            지역·생활권·역세권·이용장소 안내
          </h1>
          <p class="hero__subtitle">
            {siteConfig.name}에서 서울·경기·인천 전 지역을 행정구역, 생활권, 지하철역,
            자택·호텔·오피스텔 이용 장소 기준으로 확인하세요. 예약 전 확인사항과
            추가 이동비 기준까지 안내합니다.
          </p>
          <div class="hero__cta">
            <a href="/area/" class="btn btn-accent btn-lg">지역별 보기</a>
            <a href="/life/" class="btn btn-outline btn-lg">생활권 보기</a>
            <a href="/station/" class="btn btn-outline btn-lg">지하철역 보기</a>
            <a href="/check/" class="btn btn-ghost btn-lg">예약 전 확인</a>
          </div>
        </div>
        <div class="hero__image">
          <img
            src="/images/hero.webp"
            alt="WE 마사지 - 수도권 출장마사지 방문 안내 (스파룸 이미지)"
            width="820"
            height="615"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>

    {/* === Section 1. 통계 === */}
    <section class="section">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-card__num">3</div>
          <div class="stat-card__label">수도권 광역단체</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__num">{totalLifeAreas}</div>
          <div class="stat-card__label">핵심 생활권</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__num">{totalUseCases}</div>
          <div class="stat-card__label">이용 장소별 안내</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__num">9</div>
          <div class="stat-card__label">예약 전 확인 항목</div>
        </div>
      </div>

      <h2 class="section-title">
        수도권은 <span class="accent">네 가지 기준</span>으로 찾아야 합니다
      </h2>
      <div class="prose" style="max-width: 780px;">
        <p>
          수도권은 행정구역만으로 예약 기준을 판단하기 어렵습니다. 같은 구 안에서도
          역세권과 주거 지역, 업무지구와 외곽은 방문 환경이 전혀 다르기 때문입니다.
        </p>
        <p>
          <strong>서울</strong>은 행정구와 지하철역 기준이 강하고,
          <strong>경기</strong>는 시·군과 신도시, 차량 이동 기준이 함께 작용합니다.
          <strong>인천</strong>은 구·군별 생활권과 공항·도서 지역 여부가 중요한 변수입니다.
        </p>
        <p>
          그래서 {siteConfig.name}은 지역, 생활권, 역세권, 이용 장소 4가지 기준으로
          수도권 전체를 안내합니다. 지역명만 바꾼 페이지가 아니라, 각 지역의 실제
          방문 환경과 예약 전 확인사항을 차별화하여 제공합니다.
        </p>
      </div>
    </section>

    <hr class="divider" />

    {/* === Section 2. 네 가지 기준 카드 === */}
    <section class="section">
      <h2 class="section-title">원하는 <span class="accent">기준</span>으로 지역을 선택하세요</h2>
      <p class="section-subtitle">
        행정구역·생활권·역세권·이용 장소 중 찾는 방식에 맞춰 이동하세요.
      </p>
      <div class="card-grid">
        <a href="/area/" class="card">
          <h3 class="card__title">지역별 보기</h3>
          <p class="card__desc">
            서울 25개 구, 경기 31개 시·군, 인천 9구 2군 기준으로 방문 가능 지역을 확인합니다.
          </p>
          <span class="card__link">지역별 보기 →</span>
        </a>
        <a href="/life/" class="card">
          <h3 class="card__title">생활권 보기</h3>
          <p class="card__desc">
            강남역·역삼, 분당·판교, 송도국제도시처럼 실제 이용자가 부르는 생활권 기준입니다.
          </p>
          <span class="card__link">생활권 보기 →</span>
        </a>
        <a href="/station/" class="card">
          <h3 class="card__title">지하철역 보기</h3>
          <p class="card__desc">
            강남역, 수원역, 부평역처럼 역세권 기준으로 가까운 지역을 확인합니다.
          </p>
          <span class="card__link">역세권 보기 →</span>
        </a>
        <a href="/use/" class="card">
          <h3 class="card__title">이용 장소 보기</h3>
          <p class="card__desc">
            자택, 호텔·숙소, 오피스텔, 업무지구, 외곽 지역 기준으로 확인사항이 다릅니다.
          </p>
          <span class="card__link">이용 장소 보기 →</span>
        </a>
      </div>
    </section>

    <hr class="divider" />

    {/* === Section 3. 수도권 지역별 안내 === */}
    <section class="section" id="regions">
      <h2 class="section-title">서울·경기·인천 <span class="accent">지역별 안내</span></h2>
      <p class="section-subtitle">
        광역자치단체별 핵심 생활권과 방문 특성을 확인하세요.
      </p>
      <div class="card-grid">
        <a href="/seoul/" class="card">
          <div class="tag tag-accent" style="margin-bottom: 12px; display: inline-block;">서울</div>
          <h3 class="card__title">서울 25개 행정구</h3>
          <p class="card__desc">
            강남, 잠실, 홍대, 여의도, 성수, 용산, 목동, 연신내 등 서울 주요 생활권과 역세권.
          </p>
          <span class="card__link">서울 안내 →</span>
        </a>
        <a href="/gyeonggi/" class="card">
          <div class="tag tag-accent" style="margin-bottom: 12px; display: inline-block;">경기</div>
          <h3 class="card__title">경기 31개 시·군</h3>
          <p class="card__desc">
            수원, 분당, 용인, 부천, 안산, 안양, 일산, 동탄, 화성, 의정부 등 경기 주요 생활권.
          </p>
          <span class="card__link">경기 안내 →</span>
        </a>
        <a href="/incheon/" class="card">
          <div class="tag tag-accent" style="margin-bottom: 12px; display: inline-block;">인천</div>
          <h3 class="card__title">인천 9구 2군</h3>
          <p class="card__desc">
            송도, 부평, 구월, 주안, 청라, 검단, 영종, 인천공항, 강화·옹진 등 인천 생활권.
          </p>
          <span class="card__link">인천 안내 →</span>
        </a>
      </div>
    </section>

    {/* === 가격표 === */}
    <section class="section" style="border-top: 1px solid var(--color-border);">
      <PriceTable />
    </section>

    {/* === 전화 CTA === */}
    <PhoneCTA />

    {/* === Section 4. 수도권 핵심 생활권 === */}
    <section class="section">
      <h2 class="section-title">수도권 주요 <span class="accent">생활권별 방문 가능 지역</span></h2>
      <p class="section-subtitle">
        행정구역이 아닌 실제 생활권 단위로 방문 환경을 확인하세요.
      </p>

      {seoulAreas.length > 0 && (
        <>
          <h3 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 18px; color: var(--color-text);">
            서울 생활권
          </h3>
          <div class="card-grid" style="margin-bottom: 44px;">
            {seoulAreas.map((area) => (
              <a href={`/seoul/life/${area.slug}/`} class="card">
                <div class="tag tag-accent" style="margin-bottom: 10px; display: inline-block;">서울 생활권</div>
                <h3 class="card__title">{area.name}</h3>
                <p class="card__desc">{area.description}</p>
                <span class="card__link">방문 가능 지역 보기 →</span>
              </a>
            ))}
          </div>
        </>
      )}

      {gyeonggiAreas.length > 0 && (
        <>
          <h3 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 18px; color: var(--color-text);">
            경기 생활권
          </h3>
          <div class="card-grid" style="margin-bottom: 44px;">
            {gyeonggiAreas.map((area) => (
              <a href={`/gyeonggi/life/${area.slug}/`} class="card">
                <div class="tag tag-accent" style="margin-bottom: 10px; display: inline-block;">경기 생활권</div>
                <h3 class="card__title">{area.name}</h3>
                <p class="card__desc">{area.description}</p>
                <span class="card__link">방문 가능 지역 보기 →</span>
              </a>
            ))}
          </div>
        </>
      )}

      {incheonAreas.length > 0 && (
        <>
          <h3 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 18px; color: var(--color-text);">
            인천 생활권
          </h3>
          <div class="card-grid">
            {incheonAreas.map((area) => (
              <a href={`/incheon/life/${area.slug}/`} class="card">
                <div class="tag tag-accent" style="margin-bottom: 10px; display: inline-block;">인천 생활권</div>
                <h3 class="card__title">{area.name}</h3>
                <p class="card__desc">{area.description}</p>
                <span class="card__link">방문 가능 지역 보기 →</span>
              </a>
            ))}
          </div>
        </>
      )}
    </section>

    <hr class="divider" />

    {/* === Section 5. 예약 전 체크리스트 === */}
    <section class="section">
      <Checklist />
    </section>

    <hr class="divider" />

    {/* === Section 5b. 고객 후기 === */}
    <section class="section">
      <ReviewList limit={6} />
    </section>

    <hr class="divider" />

    {/* === Section 6. 운영 기준 (Google 가이드라인 준수) === */}
    <section class="section">
      <h2 class="section-title">중복 없는 <span class="accent">지역 페이지 운영 기준</span></h2>
      <div class="prose" style="max-width: 780px;">
        <p>
          {siteConfig.name}은 지역명만 바꾼 얇은 페이지를 만들지 않습니다.
          각 지역 페이지는 실제 생활권, 가까운 역, 방문 주소 기준, 이용 장소별
          확인사항을 다르게 작성합니다.
        </p>
        <ul>
          <li>출구별 페이지, 환승역 노선별 페이지, 번호동별 대량 페이지는 만들지 않습니다.</li>
          <li>본문이 부족한 행정동이나 검색 수요가 낮은 세부 지역은 색인에서 제외합니다.</li>
          <li>모든 주요 페이지에 예약 전 확인사항과 개인정보 처리 기준을 포함합니다.</li>
          <li>불법·선정적 서비스 불가 안내를 명확히 제공합니다.</li>
          <li>지자체·대중교통 운영사 등 공식 출처를 참고 자료로 표시합니다.</li>
        </ul>
        <div class="callout callout-info">
          <div class="callout__title">정보 안내 목적 안내</div>
          본 사이트는 합법적인 방문형 건강 관리(스포츠 마사지, 체형 관리 등) 정보 제공 목적으로
          운영됩니다. 불법 행위 및 선정적 서비스는 제공하지 않으며, 허위 후기나 가짜 평점도
          사용하지 않습니다.
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
