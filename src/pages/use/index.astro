---
/**
 * 이용 장소 허브 (/use/)
 * 스펙 13절 - 이용 장소별(자택·호텔·오피스텔·업무지구·역세권·야간·외곽) 안내
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getAllUseCases, getReviewsData } from '../../lib/data';
import { breadcrumbSchema, webPageSchema, organizationSchema, reviewsSchema } from '../../lib/schema';

const path = '/use/';
const title = '수도권 출장마사지 이용 장소별 안내｜자택·호텔·오피스텔·외곽';
const description =
  '출장마사지 이용 장소별 확인사항. 자택·호텔·오피스텔·업무지구·역세권·야간·외곽 지역별로 출입·이동비·예약 기준이 다릅니다.';

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '이용 장소별 안내', url: '/use/' },
];

const schemas = [
  organizationSchema(),
  reviewsSchema(getReviewsData(), '수도권 출장마사지 이용 장소별 안내'),
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
];

const useCases = getAllUseCases();
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 32px 0 40px;">
      <div class="tag tag-accent" style="margin-bottom: 16px;">이용 장소별 안내</div>
      <h1 style="font-size: 2.2rem; font-weight: 800; line-height: 1.3; letter-spacing: -0.02em; margin-bottom: 16px;">
        이용 장소에 따라 <span class="accent-text">확인할 내용</span>이 다릅니다
      </h1>
      <p style="font-size: 1.05rem; color: var(--color-text-soft); max-width: 680px; line-height: 1.7;">
        자택·호텔·오피스텔·업무지구·역세권·야간·외곽 지역마다 출입 방식, 주차, 추가 이동비, 사전 예약 기준이 다릅니다.
        이용하실 장소에 맞는 확인사항을 먼저 읽어주세요.
      </p>
    </section>

    <section class="section" style="border-top: 1px solid var(--color-border); padding-top: 48px;">
      <h2 class="section-title">이용 장소 <span class="accent">선택</span></h2>
      <div class="card-grid">
        {useCases.map((uc) => (
          <a href={`/use/${uc.slug}/`} class="card">
            <h3 class="card__title">{uc.label}</h3>
            <p class="card__desc">{uc.summary}</p>
            <span class="card__link">확인하기 →</span>
          </a>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
