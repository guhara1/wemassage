---
/**
 * 이용 장소별 상세 페이지 (동적)
 * /use/[slug]/
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import Checklist from '../../components/Checklist.astro';
import PriceTable from '../../components/PriceTable.astro';
import ExternalSources from '../../components/ExternalSources.astro';
import { getAllUseCases, getReviewsData } from '../../lib/data';
import type { UseCaseData } from '../../lib/types';
import { webPageSchema, breadcrumbSchema, faqPageSchema, reviewsSchema } from '../../lib/schema';

export const getStaticPaths = (() => {
  return getAllUseCases().map((uc) => ({
    params: { slug: uc.slug },
    props: { uc },
  }));
}) satisfies GetStaticPaths;

interface Props { uc: UseCaseData; }
const { uc } = Astro.props;
const path = `/use/${uc.slug}/`;
const title = `${uc.name}｜출장마사지 이용 확인사항 및 예약 전 점검`;
const description = uc.summary;

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '이용 장소별 안내', url: '/use/' },
  { name: uc.name, url: path },
];

const schemas = [
  reviewsSchema(getReviewsData(), uc.name),
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  faqPageSchema(uc.faq ?? []),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 24px 0 32px;">
      <div class="tag tag-accent" style="margin-bottom: 14px;">이용 장소별 안내</div>
      <h1 style="font-size: 2rem; font-weight: 800; line-height: 1.35; margin-bottom: 14px;">{uc.name}</h1>
      <p style="color: var(--color-text-soft); font-size: 1.05rem;">{uc.summary}</p>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <div class="prose">
        <p set:html={uc.body.replace(/\n/g, '<br />')}></p>
      </div>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <h2 class="section-title">확인 포인트</h2>
      <ul style="padding-left: 1.2em;">
        {uc.points.map((point) => (
          <li style="padding: 8px 0; color: var(--color-text-soft); list-style: disc; margin-left: 0.4em;">{point}</li>
        ))}
      </ul>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <PriceTable title={`${uc.name} 가격표`} />
    </section>

    {uc.faq && uc.faq.length > 0 && (
      <section class="section-sm" style="border-top: 1px solid var(--color-border);">
        <h2 class="section-title" style="font-size: 1.5rem;">자주 묻는 질문</h2>
        <FAQ faqs={uc.faq} />
      </section>
    )}

    {uc.externalLinks && uc.externalLinks.length > 0 && (
      <ExternalSources links={uc.externalLinks} />
    )}

  </div>
</BaseLayout>
