---
/**
 * 외부 권위 출처(참고 자료) 컴포넌트
 * E-E-A-T 신뢰 신호용 — 지자체·공식 기관·대중교통 운영사 링크.
 * 모든 외부 링크는 target="_blank" rel="noopener noreferrer".
 */
import type { ExternalLink } from '../lib/types';

interface Props {
  links: ExternalLink[];
  title?: string;
}
const { links, title = '참고 자료' } = Astro.props;

if (!links || links.length === 0) return null;
---

<div class="sources">
  <div class="sources__title">{title}</div>
  <div class="sources__desc">본 안내의 행정·교통 정보는 아래 공식 자료를 참고했습니다.</div>
  <div class="sources__list">
    {links.map((link) => (
      <a
        href={link.url}
        class="sources__item"
        target="_blank"
        rel="noopener noreferrer"
        title={link.desc}
      >
        🔗 {link.label}
      </a>
    ))}
  </div>
</div>
