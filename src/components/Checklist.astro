---
/**
 * 예약 전 체크리스트 컴포넌트
 * 데이터: src/data/common/checklists.json (9개 항목)
 */
import { getChecklist } from '../lib/data';

interface Props {
  title?: string;
}
const { title = '예약 전 반드시 확인할 내용' } = Astro.props;
const items = getChecklist();
---

<div class="checklist">
  <h2 class="checklist__title">{title}</h2>
  {items.map((item, idx) => (
    <div class="checklist__item">
      <div class="checklist__icon">{idx + 1}</div>
      <div>
        <div class="checklist__question">{item.question}</div>
        {item.detail && <div class="checklist__detail">{item.detail}</div>}
      </div>
    </div>
  ))}
</div>
